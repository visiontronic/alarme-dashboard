# Variáveis de ambiente do dashboard
# No Railway, configure estas variáveis no painel do projeto (aba Variables).
# Localmente, o servidor usa valores padrão se elas não existirem.

# Senha de acesso ao dashboard (OBRIGATÓRIO trocar em produção)
DASHBOARD_SENHA=troque_por_uma_senha_forte

# Broker MQTT (mesmo usado pelo ESP32)
MQTT_BROKER=mqtt://mqtt-dashboard.com:1883

# Tópico base do alarme (deve bater com o do firmware)
TOPICO_BASE=alarme/carro01

# Porta - o Railway define automaticamente, não precisa configurar
# PORT=3000
